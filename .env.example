# Copy this file to .env and fill in your values
# Never commit .env to git

PORT=3000

# Admin key — set a strong random string to protect /api/admin/* routes
ADMIN_KEY=change-me-before-launch

# Gmail SMTP — use an App Password, NOT your account password
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=you@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Reply-to shown in confirmation emails
FROM_NAME=Double Shot Electric
FROM_EMAIL=you@gmail.com

# Site URL shown in email links (no trailing slash)
SITE_URL=http://localhost:3000
